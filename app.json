{
  "expo": {
    "name": "夜航",
    "description": "记录生活，沿时间之流探索未知。",
    "slug": "rnTestProject",
    "version": "1.0.1",
    "backgroundColor": "#081A2F",
    "orientation": "default",
    "icon": "./assets/images/liuyinji-icon-opaque.png",
    "scheme": "rntestproject",
    "userInterfaceStyle": "automatic",
    "ios": {
      "backgroundColor": "#081A2F",
      "icon": "./assets/images/liuyinji-icon-opaque.png",
      "bundleIdentifier": "com.yangwujie.rnTestProject",
      "buildNumber": "2",
      "requireFullScreen": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/images/liuyinji-icon-opaque.png",
      "adaptiveIcon": {
        "backgroundColor": "#081A2F",
        "foregroundImage": "./assets/images/liuyinji-mark.png"
      },
      "versionCode": 2,
      "predictiveBackGestureEnabled": false,
      "package": "com.yangwujie.rnTestProject"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/liuyinji-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#081A2F",
          "image": "./assets/images/liuyinji-mark.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#081A2F",
            "image": "./assets/images/liuyinji-mark.png"
          }
        }
      ],
      "expo-sharing",
      "expo-system-ui",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableBundleCompression": true,
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3088c58e-b07a-44b6-a5e7-cede0025e0cc"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3088c58e-b07a-44b6-a5e7-cede0025e0cc"
    }
  }
}
