{
  "cli": {
    "version": ">= 19.0.8",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "env": {
        "APP_NAME": "夜航",
        "NODE_ENV": "production"
      },
      "android": {
        "buildType": "apk",
        "distribution": "store"
      },
      "channel": "production"
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "distribution": "internal"
      },
      "channel": "preview"
    },
    "development": {
      "env": {
        "APP_NAME": "夜航-dev",
        "DEV_FEATURES": "true"
      },
      "developmentClient": true,
      "ios": {
        "distribution": "internal"
      },
      "android": {
        "buildType": "apk",
        "distribution": "internal"
      },
      "channel": "development"
    }
  },
  "submit": {
    "production": {}
  }
}
